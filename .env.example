# Copy to .env and fill in real values. NEVER commit .env.
# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Groq (brain) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- App server ---
# Reserved ngrok static domain (see CONTINUE.md) — same URL every restart,
# start the tunnel with: ngrok http --url=https://catcall-desktop-mankind.ngrok-free.dev <PORT>
APP_SERVER_PUBLIC_URL=https://catcall-desktop-mankind.ngrok-free.dev
APP_SERVER_SHARED_SECRET=
PORT=3000

# --- TTS / STT ---
# Format: [voiceId]-[model]-[speed]_[stability]_[similarity]
TTS_PROVIDER=ElevenLabs
TTS_VOICE_EN=OYTbf65OHHFELVut7v2H-turbo_v2_5-1.0_0.35_0.8
TTS_VOICE_JA=3321Alera3fXjEWjjbAX-turbo_v2_5-1.0_0.35_0.8
ELEVENLABS_API_KEY=
TRANSCRIPTION_PROVIDER=google

# --- Compare mode ---
COMPARE_MODE_SERIALIZE=false

# --- Supabase (for shared gbrain across laptops) ---
# gbrain uses the Session Pooler Postgres URL, not the REST URL.
# Get it from: Supabase Dashboard -> Settings -> Database -> Connection Pooler -> Session
# Format: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_POOLER_URL=
