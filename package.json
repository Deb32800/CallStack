{
  "name": "callstack",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "shared",
    "app-server",
    "mcp-server"
  ],
  "scripts": {
    "typecheck": "tsc -p app-server/tsconfig.json --noEmit && tsc -p mcp-server/tsconfig.json --noEmit && tsc -p shared/tsconfig.json --noEmit",
    "dev:app": "tsx watch app-server/src/index.ts",
    "dev:mcp": "tsx mcp-server/src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
